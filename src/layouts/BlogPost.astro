---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  description: string;
  heroImage?: string;
  tags?: string[];
}

const { title, pubDate, updatedDate, description, heroImage, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    {heroImage && (
      <div class="hero-image">
        <img src={heroImage} alt={title} />
      </div>
    )}
    <div class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span class="updated">
            （更新于 <FormattedDate date={updatedDate} />）
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div class="post-content">
      <slot />
    </div>
    <div class="post-reward">
      <p class="reward-title">☕ 觉得文章有帮助？请我喝杯咖啡</p>
      <div class="reward-qr">
        <div class="reward-item">
          <img src="/wechat.png" alt="微信赞赏码" />
          <span>微信赞赏</span>
        </div>
        <div class="reward-item">
          <img src="/alipay.jpg" alt="支付宝收款码" />
          <span>支付宝赞赏</span>
        </div>
      </div>
    </div>
    <div class="post-nav">
      <a href="/">← 返回首页</a>
    </div>
  </article>
</BaseLayout>
