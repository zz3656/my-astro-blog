---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, AUTHOR, SOCIAL_LINKS } from '../consts';
---

<BaseLayout title={`关于 | ${SITE_TITLE}`}>
  <section class="about">
    <h1>关于我</h1>
    <div class="about-content">
      <p>
        你好！我是 <strong>{AUTHOR}</strong>，一个热爱技术的博主。
      </p>
      <p>
        这个博客使用 <a href="https://astro.build" target="_blank">Astro</a> 构建，
        部署在 GitHub Pages 上。 Astro 是一个现代化的静态站点生成器，
        专注于内容网站，构建速度极快，输出纯净的 HTML。
      </p>
      <h2>为什么选择 Astro？</h2>
      <ul>
        <li>🚀 <strong>极快的构建速度</strong> — 内容驱动的架构</li>
        <li>📦 <strong>零 JS 默认</strong> — 输出纯 HTML，按需水合</li>
        <li>🎨 <strong>组件灵活</strong> — 支持 React、Vue、Svelte 等框架</li>
        <li>📝 <strong>Markdown/MDX</strong> — 原生内容集合支持</li>
        <li>🐙 <strong>GitHub Pages 友好</strong> — 开箱即用的部署方案</li>
      </ul>
      <h2>联系我</h2>
      <div class="about-links">
        {SOCIAL_LINKS.github && <a href={SOCIAL_LINKS.github} target="_blank" class="btn btn-secondary">GitHub</a>}
        {SOCIAL_LINKS.email && <a href={SOCIAL_LINKS.email} class="btn btn-secondary">Email</a>}
      </div>
    </div>
  </section>
</BaseLayout>
